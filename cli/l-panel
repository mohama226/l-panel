#!/usr/bin/env bash

set -Eeuo pipefail

BASE_DIR="$(cd "$(dirname "$(readlink -f "$0")")" && pwd)"

VERSION_FILE="/opt/l-panel/VERSION"
LAST_UPDATE_FILE="/opt/l-panel/.last_update"

VERSION="Unknown"
LAST_UPDATE="Never"

[[ -f "$VERSION_FILE" ]] && VERSION="$(cat "$VERSION_FILE")"
[[ -f "$LAST_UPDATE_FILE" ]] && LAST_UPDATE="$(cat "$LAST_UPDATE_FILE")"

show_header() {

    clear

    echo
    echo "=========================================================="
    echo "                      L-PANEL"
    echo "=========================================================="
    echo
    echo " Version     : $VERSION"
    echo " Last Update : $LAST_UPDATE"
    echo
    echo "=========================================================="
    echo

}

run_cmd() {

    local cmd="$1"

    if [[ -x "$BASE_DIR/commands/$cmd" ]]; then
        bash "$BASE_DIR/commands/$cmd"
    else
        echo
        echo "Command not found : $cmd"
        echo
        read -rp "Press ENTER..."
    fi

}

while true
do

show_header

echo " 1) Install / Repair"
echo " 2) Install Ocserv"
echo " 3) Users"
echo " 4) Dashboard"
echo " 5) Status"
echo " 6) Services"
echo " 7) Firewall"
echo " 8) SSL"
echo " 9) Backup"
echo "10) Restore"
echo "11) Fail2Ban"
echo "12) Logs"
echo "13) Server Information"
echo "14) Update Panel"
echo "15) Uninstall Panel"

echo
echo " 0) Exit"
echo

read -rp "Select option : " MENU

case "$MENU" in

1)

run_cmd install.sh

;;

2)

run_cmd ocserv.sh

;;

3)

run_cmd users.sh

;;

4)

run_cmd dashboard.sh

;;

5)

run_cmd status.sh

;;

6)

run_cmd services.sh

;;

7)

run_cmd firewall.sh

;;

8)

run_cmd ssl.sh

;;

9)

run_cmd backup.sh

;;

10)

run_cmd restore.sh

;;

11)

run_cmd fail2ban.sh

;;
12)

run_cmd logs.sh

;;

13)

run_cmd info.sh

;;

14)

run_cmd update.sh

;;

15)

run_cmd uninstall.sh

;;

0)

clear

echo
echo "Goodbye."
echo

exit 0

;;

*)

echo

echo "Invalid option."

sleep 1

;;

esac

done
