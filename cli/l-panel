#!/usr/bin/env bash

set -Eeuo pipefail


BASE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"


source "$BASE_DIR/lib/colors.sh"
source "$BASE_DIR/lib/common.sh"
source "$BASE_DIR/lib/version.sh"



#############################################
# Command Paths
#############################################

INSTALL_CMD="$BASE_DIR/commands/install.sh"

UPDATE_CMD="$BASE_DIR/commands/update.sh"

OCSERV_CMD="$BASE_DIR/commands/ocserv.sh"

UNINSTALL_CMD="$BASE_DIR/commands/uninstall.sh"



#############################################
# Check Commands
#############################################

check_command(){

    if [[ ! -f "$1" ]]; then

        fail "Command not found: $1"

        exit 1

    fi

}



#############################################
# Show Menu
#############################################

show_menu(){


show_header


echo "1) Install L-Panel"

echo "2) Install Ocserv 1.5.0"

echo "3) Update L-Panel"

echo "4) Uninstall L-Panel"

echo

echo "0) Exit"

echo


}



#############################################
# Run Menu
#############################################

menu_loop(){


while true; do


    show_menu


    read -rp "Select option: " OPTION



    case "$OPTION" in



        1)

            check_command "$INSTALL_CMD"

            bash "$INSTALL_CMD"

            ;;



        2)

            check_command "$OCSERV_CMD"

            bash "$OCSERV_CMD"

            ;;



        3)

            check_command "$UPDATE_CMD"

            bash "$UPDATE_CMD"

            ;;



        4)

            check_command "$UNINSTALL_CMD"

            bash "$UNINSTALL_CMD"

            ;;



        0)

            echo

            info "Bye."

            exit 0

            ;;



        *)

            fail "Invalid option."

            pause

            ;;


    esac


done


}



#############################################
# Start
#############################################

main(){


require_root


menu_loop


}



main
