# Stop systemd service if running
if systemctl is-active --quiet lpanel; then
    echo "[+] Stopping existing lpanel service..."
    systemctl stop lpanel
fi

# Kill any uvicorn already running
UVIPID=$(ps aux | grep "uvicorn app.main:app" | grep -v grep | awk '{print $2}')
if [ ! -z "$UVIPID" ]; then
    echo "[+] Killing existing uvicorn process: $UVIPID"
    kill -9 $UVIPID
fi

# Check if port is free
if ss -tulnp | grep ":$PANELPORT" > /dev/null; then
    echo "[!] Port $PANELPORT is already in use. Cannot start panel."
    exit 1
fi
