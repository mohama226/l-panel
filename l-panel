#!/bin/bash

# Install git if missing
if ! command -v git &> /dev/null; then
    echo "[+] Installing git..."
    dnf install -y git
fi

# Auto-detect project directory
SCRIPT_PATH=$(readlink -f "$0")
PROJECT_DIR=$(dirname "$SCRIPT_PATH")

# If project folder is empty, clone it
if [ ! -d "$PROJECT_DIR/app" ]; then
    echo "[+] Project not found. Cloning l-panel..."
    cd /opt
    git clone https://github.com/mohama226/l-panel
    PROJECT_DIR="/opt/l-panel"
fi

cd "$PROJECT_DIR"

# Load last update time
if [ -f last_update.txt ]; then
    LAST_UPDATE=$(cat last_update.txt)
else
    LAST_UPDATE="No updates yet"
fi

clear
echo "===== l-panel ====="
echo "Last update: $LAST_UPDATE"
echo "1) Install l-panel"
echo "2) Update l-panel"
echo "3) Install ocserv 1.5.0"
echo "4) Run Web Panel"
echo "-------------------"
read -p "Choose: " opt

case $opt in
    1) bash "$PROJECT_DIR/install/install.sh" ;;
    2) bash "$PROJECT_DIR/install/update.sh" ;;
    3) bash "$PROJECT_DIR/install/install_ocserv.sh" ;;
    4)
        read -p "Enter panel port (default 2096): " PANELPORT
        PANELPORT=${PANELPORT:-2096}

        export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/usr/local/sbin

        cd "$PROJECT_DIR"
        uvicorn app.main:app --host 0.0.0.0 --port $PANELPORT
        ;;
    *)
        echo "Invalid option"
        ;;
esac
