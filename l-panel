#!/bin/bash

# Auto-detect project directory even when executed via curl
if [[ -L "$0" ]]; then
    PROJECT_DIR=$(dirname "$(readlink -f "$0")")
else
    PROJECT_DIR=$(cd "$(dirname "$0")"; pwd)
fi

cd "$PROJECT_DIR"

# Load last update time
if [ -f last_update.txt ]; then
    LAST_UPDATE=$(cat last_update.txt)
else
    LAST_UPDATE="No updates yet"
fi

clear
echo "===== l-panel ====="
echo "Last update: $LAST_UPDATE"
echo "1) Install l-panel"
echo "2) Update l-panel"
echo "3) Install ocserv 1.5.0"
echo "4) Run Web Panel"
echo "-------------------"
read -p "Choose: " opt

case $opt in
    1) bash install/install.sh ;;
    2) bash install/update.sh ;;
    3) bash install/install_ocserv.sh ;;
    4)
        read -p "Enter panel port (default 2096): " PANELPORT
        PANELPORT=${PANELPORT:-2096}

        # Ensure uvicorn is available
        export PATH=/usr/local/bin:/usr/bin:/bin:/usr/sbin:/usr/local/sbin

        cd "$PROJECT_DIR"
        uvicorn app.main:app --host 0.0.0.0 --port $PANELPORT
        ;;
    *)
        echo "Invalid option"
        ;;
esac
